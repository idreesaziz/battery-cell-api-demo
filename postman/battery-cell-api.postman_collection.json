{
  "info": {
    "_postman_id": "b4tt3ry-c3ll-ap1-d3m0-c0ll3ct10n",
    "name": "Battery Cell Telemetry API",
    "description": "Postman collection for the Battery Cell Telemetry REST API demo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "cellId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Create Battery Cell",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.id) {",
              "  pm.collectionVariables.set('cellId', res.id);",
              "}",
              "",
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Has id', () => pm.expect(res).to.have.property('id'));",
              "pm.test('Has serialNumber', () => pm.expect(res.serialNumber).to.eql('CELL-2024-00042'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"serialNumber\": \"CELL-2024-00042\",\n  \"voltage\": 3.72,\n  \"temperature\": 28.5,\n  \"stateOfCharge\": 87.3,\n  \"stateOfHealth\": 99.1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/cells",
          "host": ["{{baseUrl}}"],
          "path": ["cells"]
        },
        "description": "Create a new battery cell telemetry entry."
      },
      "response": []
    },
    {
      "name": "Get All Battery Cells",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cells",
          "host": ["{{baseUrl}}"],
          "path": ["cells"]
        },
        "description": "Return all battery cell telemetry entries."
      },
      "response": []
    },
    {
      "name": "Get Battery Cell by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Has correct id', () => {",
              "  const res = pm.response.json();",
              "  pm.expect(res.id).to.eql(pm.collectionVariables.get('cellId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cells/{{cellId}}",
          "host": ["{{baseUrl}}"],
          "path": ["cells", "{{cellId}}"]
        },
        "description": "Return a single battery cell by its UUID."
      },
      "response": []
    },
    {
      "name": "Update Battery Cell",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Voltage updated', () => {",
              "  const res = pm.response.json();",
              "  pm.expect(res.voltage).to.eql(3.85);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"voltage\": 3.85,\n  \"temperature\": 30.2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/cells/{{cellId}}",
          "host": ["{{baseUrl}}"],
          "path": ["cells", "{{cellId}}"]
        },
        "description": "Partially update a battery cell entry."
      },
      "response": []
    },
    {
      "name": "Delete Battery Cell",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 204', () => pm.response.to.have.status(204));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cells/{{cellId}}",
          "host": ["{{baseUrl}}"],
          "path": ["cells", "{{cellId}}"]
        },
        "description": "Delete a battery cell entry by UUID."
      },
      "response": []
    }
  ]
}
